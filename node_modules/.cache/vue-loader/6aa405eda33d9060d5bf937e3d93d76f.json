CA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Actividad.vue","sourceRoot":"src/views","sourcesContent":["<template lang=\"pug\">\n  .curso-main-container.pb-3\n    BannerInterno(icono=\"far fa-question-circle\" titulo=\"Actividad didáctica\")\n    .container.tarjeta.tarjeta--blanca.p-4.p-md-5\n  \n      #Actividad                \n        <Actividad :cuestionario=\"cuestionario\"/>\n  \n  </template>\n<script>\nimport Actividad from 'ecored-pkg-fliz/plugin/components/actividad/Actividad.vue'\nexport default {\n  name: 'ActividadDidactica',\n  components: {\n    Actividad,\n  },\n  data: () => ({\n    cuestionario: {\n      tema: 'Nombre del CF',\n      titulo: 'Cuestionario',\n      introduccion:\n        '<b> Objetivo:</b> Evaluar la comprensión sobre los procesos de confección en marroquinería, verificando conocimientos clave sobre técnicas, materiales y medidas de seguridad.',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto:\n            'El armado en marroquinería consiste únicamente en la unión de piezas con adhesivos, sin necesidad de costuras.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 2,\n          texto:\n            'La función principal del bolsillo con cierre es permitir el almacenamiento seguro de objetos.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 3,\n          texto:\n            'En la confección de bolsos, los bolsillos siempre se cosen después de ensamblar todas las partes del bolso.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 4,\n          texto:\n            'En la fabricación de un bolso con base, el proceso de \"envivar\" ayuda a reforzar la estructura del bolso.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 5,\n          texto:\n            'El proceso de entalegar cierre se utiliza únicamente en la confección de billeteras.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 6,\n          texto:\n            'La seguridad en la industria marroquinera incluye el uso de elementos de protección personal como tapabocas, guantes y gafas.',\n          imagen: require('@/assets/actividad/imagen2.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 7,\n          texto:\n            'El pespunte es un tipo de costura utilizado para reforzar uniones y mejorar el acabado de los productos.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 8,\n          texto:\n            'El cemento de contacto XL es un tipo de adhesivo que se emplea en la marroquinería para unir materiales.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 9,\n          texto:\n            'Para evitar accidentes en la marroquinería, es recomendable operar las máquinas mientras están en funcionamiento para ajustarlas.',\n          imagen: require('@/assets/actividad/imagen1.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 10,\n          texto:\n            'La terminación y el empaque del producto marroquinero no influyen en su calidad ni en su aceptación en el mercado.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n      ],\n      mensaje_final_aprobado: '¡Excelente! Ha superado la actividad.',\n      mensaje_final_reprobado:\n        'Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n}\n</script>\n"]}]}